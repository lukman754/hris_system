Options -Indexes

RewriteEngine On

# Redirect ke HTTPS jika perlu (uncomment jika perlu)
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Semua request ke /api/* diarahkan ke api/index.php
RewriteCond %{REQUEST_URI} ^/hris_system/api/
RewriteRule ^hris_system/api/.*$ /hris_system/api/index.php [L,QSA]

# Static assets (css, js, img) - bypass rewrite
RewriteCond %{REQUEST_URI} \.(css|js|png|jpg|jpeg|gif|ico|svg|woff|woff2)$
RewriteRule ^ - [L]

# Semua request lain ke index.php (SPA)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^hris_system/.*$ /hris_system/index.php [L]
